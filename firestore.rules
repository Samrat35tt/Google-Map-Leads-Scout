rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function isNewDocOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.ownerId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email']) &&
             data.id is string &&
             data.email is string;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['id', 'name', 'ownerId']) &&
             data.id is string &&
             data.name is string &&
             data.ownerId is string;
    }

    function isValidKnowledge(data) {
      return data.keys().hasAll(['id', 'title', 'content', 'ownerId']) &&
             data.id is string &&
             data.title is string &&
             data.content is string &&
             data.ownerId is string;
    }

    function isValidMeeting(data) {
      return data.keys().hasAll(['id', 'title', 'ownerId']) &&
             data.id is string &&
             data.title is string &&
             data.ownerId is string;
    }

    function isValidConversation(data) {
      return data.keys().hasAll(['id', 'leadId', 'ownerId']) &&
             data.id is string &&
             data.leadId is string &&
             data.ownerId is string;
    }

    function isValidSearchLog(data) {
      return data.keys().hasAll(['id', 'industry', 'ownerId']) &&
             data.id is string &&
             data.industry is string &&
             data.ownerId is string;
    }

    function isValidWorkflow(data) {
      return data.keys().hasAll(['id', 'name', 'ownerId']) &&
             data.id is string &&
             data.name is string &&
             data.ownerId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /leads/{leadId} {
      allow read: if isDocOwner();
      allow create: if isNewDocOwner() && isValidLead(request.resource.data);
      allow update: if isDocOwner() && isNewDocOwner() && isValidLead(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /knowledge/{docId} {
      allow read: if isDocOwner();
      allow create: if isNewDocOwner() && isValidKnowledge(request.resource.data);
      allow update: if isDocOwner() && isNewDocOwner() && isValidKnowledge(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /meetings/{meetingId} {
      allow read: if isDocOwner();
      allow create: if isNewDocOwner() && isValidMeeting(request.resource.data);
      allow update: if isDocOwner() && isNewDocOwner() && isValidMeeting(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /conversations/{conversationId} {
      allow read: if isDocOwner();
      allow create: if isNewDocOwner() && isValidConversation(request.resource.data);
      allow update: if isDocOwner() && isNewDocOwner() && isValidConversation(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /search_history/{logId} {
      allow read: if isDocOwner();
      allow create: if isNewDocOwner() && isValidSearchLog(request.resource.data);
      allow update: if isDocOwner() && isNewDocOwner() && isValidSearchLog(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /workflows/{workflowId} {
      allow read: if isDocOwner();
      allow create: if isNewDocOwner() && isValidWorkflow(request.resource.data);
      allow update: if isDocOwner() && isNewDocOwner() && isValidWorkflow(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
